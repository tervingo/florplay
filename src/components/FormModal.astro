---
const { id, before, linkText, after } = Astro.props;
---

<span class="form-modal-inline">
  {before}
  <a href="#" class="form-modal-link" data-modal-id={id}>{linkText}</a>
  {after}
</span>

<div id={id} class="form-popup">
  <div class="form-popup-contenido">
    <span class="form-popup-cerrar">&times;</span>
    <slot />
  </div>
</div>

<style>
.form-modal-inline {
  display: inline;
}

.form-modal-link {
  color: royalblue;
  text-decoration: none;
  margin: 0 0.25em;
}

.form-modal-link:hover {
  text-decoration: underline;
}

.form-popup {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 2000;
  overflow-y: auto;
}

.form-popup-contenido {
  position: relative;
  background-color: silver;
  margin: 5% auto;
  padding: 2rem;
  width: 90%;
  max-width: 620px;
  border-radius: 5px;
  max-height: 90vh;
  overflow-y: auto;
}

.form-popup-cerrar {
  position: absolute;
  right: 12px;
  top: 6px;
  color: #666;
  font-size: 26px;
  font-weight: bold;
  cursor: pointer;
  line-height: 1;
}

.form-popup-cerrar:hover {
  color: #000;
}

@media (max-width: 768px) {
  .form-popup-contenido {
    margin: 2% auto;
    width: 96%;
    padding: 1.2rem;
    max-height: 95vh;
  }
}
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.form-modal-link').forEach(link => {
      const id = link.getAttribute('data-modal-id');
      const popup = document.getElementById(id);
      if (!popup) return;
      const cerrar = popup.querySelector('.form-popup-cerrar');

      link.addEventListener('click', e => {
        e.preventDefault();
        popup.style.display = 'block';
      });

      cerrar.addEventListener('click', () => {
        popup.style.display = 'none';
      });

      popup.addEventListener('click', e => {
        if (e.target === popup) popup.style.display = 'none';
      });
    });
  });
</script>
